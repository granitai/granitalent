# ============================================================
# Granitalent — Environment Variables
# ============================================================

# OpenAI — powers real-time interviews (Realtime API) and LLM tasks
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# ElevenLabs — TTS and STT for asynchronous interviews
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_key_here

# JWT secret for admin authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=generate_a_random_32_char_hex

# ElevenLabs voice ID for TTS — find voices at https://elevenlabs.io/voice-library
VOICE_ID=cjVigY5qzO86Huf0OWal

# Maximum interview duration in minutes
INTERVIEW_TIME_LIMIT_MINUTES=20

# ============================================================
# Optional overrides (defaults work well, only change if needed)
# ============================================================

# OpenAI Realtime model for real-time interviews
# LIVE_MODEL=gpt-realtime

# Default AI voice for real-time interviews (alloy, ash, ballad, coral, echo, sage, shimmer, verse)
# LIVE_VOICE=sage

# Server bind address and port
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# ============================================================
# S3-COMPATIBLE STORAGE
# Docker Compose sets these automatically (MinIO).
# To switch to a cloud provider, set these in .env and remove
# the minio/minio-init services from docker-compose.
# ============================================================
# S3_ENDPOINT_URL=http://minio:9000          # MinIO (Docker)
# S3_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com  # Cloudflare R2
# S3_ENDPOINT_URL=https://s3.us-east-1.amazonaws.com    # AWS S3
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_BUCKET_NAME=granitalent
# S3_REGION=us-east-1
